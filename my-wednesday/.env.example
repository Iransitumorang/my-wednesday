# Base URL backend. Wajib untuk CRUD (auth header terkirim benar).
# Dev: http://localhost:8080 (backend harus enable CORS untuk localhost:3000)
# Prod: https://api.example.com
# VITE_API_URL=http://localhost:8080


import axios from 'axios';

// Membuat instance axios dengan konfigurasi url docker quarkus lu
const api = axios.create({
  baseURL: import.meta.env.VITE_API_BASE_URL || 'http://localhost:8080',
  headers: {
    'Content-Type': 'application/json'
  }
});

export default api;
